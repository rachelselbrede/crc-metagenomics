# data_provenance.R
# Regenerates the full data provenance chain from curatedMetagenomicData
# and saves every intermediate count so the project has an auditable record
# of how the final 762-sample dataset was derived.
#
# Usage from the project root:
#   Rscript scripts/data_provenance.R
#
# Output:
#   data/raw/provenance/00_full_sampleMetadata_dim.txt
#   data/raw/provenance/01_all_conditions.csv
#   data/raw/provenance/02_crc_universe_by_cohort.csv
#   data/raw/provenance/03_thomas7_filtered_by_cohort.csv
#   data/raw/provenance/sessionInfo.txt
library(curatedMetagenomicData)
if (!require("BiocManager", quietly = TRUE)) install.packages("BiocManager")
BiocManager::install("curatedMetagenomicData")
# data_provenance.R
# Regenerates the full data provenance chain from curatedMetagenomicData
# and saves every intermediate count so the project has an auditable record
# of how the final 762-sample dataset was derived.
#
# Usage from the project root:
#   Rscript scripts/data_provenance.R
#
# Output:
#   data/raw/provenance/00_full_sampleMetadata_dim.txt
#   data/raw/provenance/01_all_conditions.csv
#   data/raw/provenance/02_crc_universe_by_cohort.csv
#   data/raw/provenance/03_thomas7_filtered_by_cohort.csv
#   data/raw/provenance/sessionInfo.txt
library(curatedMetagenomicData)
dir.create("data/raw/provenance", recursive = TRUE, showWarnings = FALSE)
# Step 0: Full sampleMetadata as it ships with the package, no filtering
data("sampleMetadata")
cat("Full sampleMetadata dimensions:",
nrow(sampleMetadata), "samples x",
ncol(sampleMetadata), "metadata columns\n")
writeLines(
c(
paste("Full sampleMetadata rows:", nrow(sampleMetadata)),
paste("Full sampleMetadata cols:", ncol(sampleMetadata)),
paste("Unique studies:", length(unique(sampleMetadata$study_name))),
paste("Snapshot date:", Sys.Date())
),
"data/raw/provenance/00_full_sampleMetadata_dim.txt"
)
# Step 1: Counts of every disease label in the entire package
all_conditions <- as.data.frame(table(sampleMetadata$study_condition,
useNA = "ifany"))
colnames(all_conditions) <- c("study_condition", "n_samples")
write.csv(all_conditions,
"data/raw/provenance/01_all_conditions.csv",
row.names = FALSE)
cat("\nAll study_condition values in the full package:\n")
print(all_conditions)
# Step 2: Filter to (CRC, adenoma, control) only, keep ALL cohorts
# This is the broad pre-filter snapshot the project started from
crc_universe <- sampleMetadata[sampleMetadata$study_condition %in%
c("CRC", "adenoma", "control"), ]
cat("\nBroad CRC-relevant universe (all cohorts, no exclusions):\n")
cat("  Total samples:", nrow(crc_universe), "\n")
print(table(crc_universe$study_condition))
universe_table <- as.data.frame.matrix(
table(crc_universe$study_name, crc_universe$study_condition)
)
universe_table$total <- rowSums(universe_table)
universe_table <- universe_table[order(-universe_table$total), ]
universe_table$study_name <- rownames(universe_table)
universe_table <- universe_table[, c("study_name", setdiff(colnames(universe_table), "study_name"))]
write.csv(universe_table,
"data/raw/provenance/02_crc_universe_by_cohort.csv",
row.names = FALSE)
cat("\nBroad universe by cohort (saved to 02_crc_universe_by_cohort.csv):\n")
print(universe_table)
# Step 3: Final filter to the 7 Thomas et al. (2019) cohorts
thomas_cohorts <- c(
"FengQ_2015", "YuJ_2015", "VogtmannE_2016",
"ThomasAM_2018a", "ThomasAM_2018b", "ThomasAM_2019_c",
"ZellerG_2014"
)
final_meta <- crc_universe[crc_universe$study_name %in% thomas_cohorts, ]
final_table <- as.data.frame.matrix(
table(final_meta$study_name, final_meta$study_condition)
)
final_table$total <- rowSums(final_table)
final_table$study_name <- rownames(final_table)
final_table <- final_table[, c("study_name", setdiff(colnames(final_table), "study_name"))]
write.csv(final_table,
"data/raw/provenance/03_thomas7_filtered_by_cohort.csv",
row.names = FALSE)
cat("\nFinal Thomas-7 filtered dataset (saved to 03_thomas7_filtered_by_cohort.csv):\n")
print(final_table)
cat("\n  Total samples after Thomas-7 filter:", nrow(final_meta), "\n")
# Step 4: Save sessionInfo so the package version is locked
sink("data/raw/provenance/sessionInfo.txt")
print(sessionInfo())
sink()
cat("\n=========================================\n")
cat("Provenance summary:\n")
cat("  Full package:", nrow(sampleMetadata), "samples\n")
cat("  Filtered to CRC/adenoma/control:", nrow(crc_universe), "samples\n")
cat("  Filtered to Thomas 7 cohorts:", nrow(final_meta), "samples\n")
cat("Files written to data/raw/provenance/\n")
